PORT=5000
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_API_KEY=replace_with_a_shared_internal_service_key
GROQ_API_KEY=your_groq_api_key_here
GITHUB_PAT=your_github_personal_access_token_here
WEBHOOK_SECRET=your_github_webhook_secret_here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
GIT_CLONE_TIMEOUT=120000
MAX_REPO_SIZE_MB=100
REPOSAGE_API_KEY=your_secure_api_key_here
# Session secret for signing session cookies. Must be a unique, random value
# distinct from REPOSAGE_API_KEY. Required in production — server will crash
# on startup if unset.
SESSION_SECRET=generate_a_unique_random_secret_here
MONGODB_URI=mongodb://localhost:27017/reposage
# Set to 'false' when running without a reverse proxy (e.g. plain local dev).
# When 'true' (default), Express trusts the X-Forwarded-For header from the first
# proxy hop so that rate limiting uses the real client IP instead of the proxy's IP.
TRUST_PROXY=true
# AI Engine constraints (must match ai-engine/app.py AnalyzeRequest limits)
AI_ENGINE_MAX_TOKENS=32768
