# RepoSage AI Engine Environment Variables
# The AI Engine can also read variables from '../backend/.env' automatically if present.

# Groq API Key (required for AI functionality)
# NOTE: Must NOT be prefixed with VITE_ — that prefix exposes keys to client bundles.
GROQ_API_KEY=your_groq_api_key_here

# Embedding model (default: all-MiniLM-L6-v2 — 384-dimensional vectors)
# Use any HuggingFace sentence-transformers model identifier
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB Vector Database
# Set CHROMA_HOST to connect to a ChromaDB server (e.g. "chromadb" when running via Docker Compose)
# Leave empty to use embedded PersistentClient mode (local file-based storage)
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_COLLECTION=reposage_code_chunks
CHROMA_PERSIST_DIR=./chroma_data
